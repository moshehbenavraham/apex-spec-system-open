# Apex Infinite CLI - API Keys
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# These keys are referenced by config.yaml using ${ENV_VAR} syntax.
# Agent settings (binary, flags, model effort) are in config.yaml, not here.

XAI_API_KEY=xai-your-key-here
OPENAI_API_KEY=sk-your-key-here
